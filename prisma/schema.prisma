generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomType {
  CODE
  TEXT
  FILES
  MIXED
}

model Room {
  id        String   @id @default(uuid()) @db.Uuid
  roomCode  String   @unique @db.VarChar(8)
  type      RoomType @default(MIXED)
  token     String   @unique // temporary room token for WS auth
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code        CodeContent?
  text        TextContent?
  files       FileObject[]
  activeUsers ActiveUser[]

  @@index([expiresAt])
  @@index([roomCode])
  @@map("rooms")
}

model CodeContent {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @unique @db.Uuid
  language  String   @default("javascript") @db.VarChar(32)
  content   String   @default("") @db.Text
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("code_contents")
}

model TextContent {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @unique @db.Uuid
  markdown  String   @default("") @db.Text
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("text_contents")
}

model FileObject {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @db.Uuid
  fileName   String   @db.VarChar(255)
  fileSize   Int
  mimeType   String   @db.VarChar(128)
  storageKey String   @db.VarChar(512)
  storageUrl String   @db.VarChar(1024)
  uploadedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("file_objects")
}

model ActiveUser {
  id            String   @id @default(uuid()) @db.Uuid
  roomId        String   @db.Uuid
  socketId      String   @unique
  anonymousName String   @db.VarChar(64)
  cursorColor   String   @db.VarChar(16)
  connectedAt   DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("active_users")
}

/// Postgres-backed rate limit buckets (replaces Redis INCR/PEXPIRE)
model RateLimitBucket {
  key       String   @id @db.VarChar(191)
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@map("rate_limit_buckets")
}
