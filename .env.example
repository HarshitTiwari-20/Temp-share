# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3001
PORT=3000
WS_PORT=3001

# Database
DATABASE_URL=postgresql://tempshare:tempshare@localhost:5433/tempshare?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO / R2
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tempshare
S3_PUBLIC_URL=http://localhost:9000/tempshare
S3_FORCE_PATH_STYLE=true

# Security
ROOM_TOKEN_SECRET=change-me-to-a-long-random-secret-in-production
MAX_FILE_SIZE_MB=100
MAX_FILES_PER_ROOM=50
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Cleanup
CLEANUP_INTERVAL_MS=60000
